rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidActivity(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.topic is string && data.topic.size() > 0 &&
             data.purpose is string && data.purpose.size() > 0 &&
             data.userId == request.auth.uid;
    }

    function isValidModelConfig(data) {
      return data.userId == request.auth.uid &&
             data.config is map &&
             data.config.id is string &&
             data.isActive is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /test/connection {
      allow read: if true;
    }

    match /model_configs/{configId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidModelConfig(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidModelConfig(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidActivity(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidActivity(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }
  }
}
